###############################
# CDSS Backend environment
# Copy to .env and fill values for local/dev.
# Render: set these as Environment Variables in the service dashboard.
###############################

# Application
CDSS_APP_NAME=CDSS Backend
CDSS_DEBUG=False

# PostgreSQL connection string (SQLAlchemy compatible)
# Example for Neon: postgresql+psycopg2://<user>:<password>@<host>/<database>
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DATABASE

# Optional: override Alembic url when running migrations locally
#SQLALCHEMY_URL=${DATABASE_URL}
